<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_estate_student_form" model="ir.ui.view">
        <field name="name">estate.student.form</field>
        <field name="model">estate.student</field>
        <field name="arch" type="xml">
            <form string="Student Form">
                <div class="student_form">
                    <div class="profile">
                        <field name="profile" widget="image" style="height: 128px; width: 128px;"/>
                    </div>
                    <div class="student_info">
                        <field name="name"/>
                        <field name="score"/>
                        <field name="dob"/>
                        <field name="gender"/>
                        <field name="age"/>
                    </div>
                </div>
            </form>
        </field>
    </record>
</odoo>
